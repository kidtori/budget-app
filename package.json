{
  "name": "budget-app",
  "version": "1.0.0",
  "description": "Personal budget manager",
  "author": "Personal",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "web": "node server.js",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.personal.budget",
    "productName": "Budget",
    "copyright": "Personal use",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "!src/styles.css"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false
    }
  }
}
